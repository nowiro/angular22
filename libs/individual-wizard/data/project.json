{
  "name": "individual-wizard-data",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/individual-wizard/data/src",
  "prefix": "a22",
  "projectType": "library",
  "tags": ["scope:individual-wizard", "type:data-access"],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p libs/individual-wizard/data/tsconfig.lib.json --noEmit"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/libs/individual-wizard/data"],
      "options": {
        "command": "vitest run",
        "cwd": "libs/individual-wizard/data"
      }
    }
  }
}
