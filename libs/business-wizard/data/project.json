{
  "name": "business-wizard-data",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/business-wizard/data/src",
  "prefix": "a22",
  "projectType": "library",
  "tags": ["scope:business-wizard", "type:data-access"],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p libs/business-wizard/data/tsconfig.lib.json --noEmit"
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{workspaceRoot}/coverage/libs/business-wizard/data"],
      "options": {
        "configFile": "libs/business-wizard/data/vitest.config.ts"
      }
    }
  }
}
