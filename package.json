{
  "name": "angular22",
  "version": "0.1.0",
  "private": true,
  "description": "Angular 22 + Nx + Angular Material demo monorepo — wizard demos built with Signal Forms",
  "license": "MIT",
  "engines": {
    "node": ">=24.15.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "start": "nx serve angular22",
    "start:angular22": "nx serve angular22",
    "start:individual": "nx serve demo-individual-wizard",
    "start:business": "nx serve demo-business-wizard",
    "start:all": "nx run-many -t serve --projects=angular22,demo-individual-wizard,demo-business-wizard --parallel=3",
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "test:cov": "nx run-many -t test --coverage",
    "e2e": "nx run-many -t e2e --parallel=1",
    "lint": "nx run-many -t lint",
    "lint:fix": "nx run-many -t lint --fix",
    "typecheck": "nx run-many -t typecheck",
    "format": "prettier --write \"**/*.{ts,html,scss,css,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,html,scss,css,json,md,yml,yaml}\"",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "graph": "nx graph",
    "affected": "nx affected",
    "affected:test": "nx affected -t test",
    "affected:lint": "nx affected -t lint",
    "affected:build": "nx affected -t build",
    "affected:e2e": "nx affected -t e2e"
  },
  "dependencies": {
    "@angular/animations": "22.0.0",
    "@angular/cdk": "22.0.0",
    "@angular/common": "22.0.0",
    "@angular/compiler": "22.0.0",
    "@angular/core": "22.0.0",
    "@angular/forms": "22.0.0",
    "@angular/material": "22.0.0",
    "@angular/platform-browser": "22.0.0",
    "@angular/router": "22.0.0",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular-devkit/core": "22.0.0",
    "@angular-devkit/schematics": "22.0.0",
    "@angular/build": "22.0.0",
    "@angular/cli": "22.0.0",
    "@angular/compiler-cli": "22.0.0",
    "@angular/language-service": "22.0.0",
    "@eslint/js": "10.0.1",
    "@nx/angular": "22.7.5",
    "@nx/devkit": "22.7.5",
    "@nx/eslint": "22.7.5",
    "@nx/eslint-plugin": "22.7.5",
    "@nx/js": "22.7.5",
    "@nx/playwright": "22.7.5",
    "@nx/web": "22.7.5",
    "@nx/workspace": "22.7.5",
    "@playwright/test": "1.60.0",
    "@schematics/angular": "22.0.0",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.40",
    "@swc/helpers": "0.5.23",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "@types/node": "25.9.2",
    "@typescript-eslint/utils": "8.60.1",
    "@vitest/coverage-v8": "4.1.8",
    "angular-eslint": "22.0.0",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-jsdoc": "63.0.2",
    "eslint-plugin-playwright": "2.10.4",
    "eslint-plugin-sonarjs": "4.0.3",
    "eslint-plugin-unicorn": "64.0.0",
    "globals": "17.6.0",
    "jiti": "2.7.0",
    "jsdom": "29.1.1",
    "nx": "22.7.5",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  }
}
