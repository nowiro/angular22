{
  "name": "angular22",
  "version": "0.1.0",
  "private": true,
  "description": "Angular 22 + Nx + Angular Material demo monorepo — wizard demos built with Signal Forms",
  "license": "MIT",
  "engines": {
    "node": ">=24.15.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "start": "nx serve portal",
    "start:portal": "nx serve portal",
    "start:individual": "nx serve demo-individual-wizard",
    "start:business": "nx serve demo-business-wizard",
    "start:all": "nx run-many -t serve --projects=portal,demo-individual-wizard,demo-business-wizard --parallel=3 --output-style=stream",
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "test:cov": "nx run-many -t test --coverage",
    "e2e": "nx run-many -t e2e --parallel=1",
    "lint": "nx run-many -t lint",
    "lint:fix": "nx run-many -t lint --fix",
    "typecheck": "nx run-many -t typecheck",
    "format": "prettier --write \"**/*.{ts,html,scss,css,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,html,scss,css,json,md,yml,yaml}\"",
    "verify": "pnpm format:check && pnpm ai:validate && pnpm sdd:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "ai:validate": "node tools/scripts/validate-ai-config.mjs",
    "sdd:check": "node tools/scripts/validate-sdd.mjs",
    "workflow:specify": "node tools/scripts/workflow-specify.mjs",
    "graph": "nx graph",
    "affected": "nx affected",
    "affected:test": "nx affected -t test",
    "affected:lint": "nx affected -t lint",
    "affected:build": "nx affected -t build",
    "affected:e2e": "nx affected -t e2e",
    "deps:check": "ncu",
    "deps:check:minor": "ncu --target minor",
    "deps:check:patch": "ncu --target patch",
    "deps:update": "ncu -u && pnpm install",
    "deps:update:minor": "ncu -u --target minor && pnpm install",
    "deps:update:patch": "ncu -u --target patch && pnpm install",
    "watchdog": "node tools/scripts/watchdog.mjs",
    "watchdog:check": "node tools/scripts/watchdog.mjs --check",
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky"
  },
  "dependencies": {
    "@angular/cdk": "22.0.1",
    "@angular/common": "22.0.1",
    "@angular/compiler": "22.0.1",
    "@angular/core": "22.0.1",
    "@angular/elements": "22.0.1",
    "@angular/forms": "22.0.1",
    "@angular/material": "22.0.1",
    "@angular/platform-browser": "22.0.1",
    "@angular/router": "22.0.1",
    "keycloak-angular": "22.0.0",
    "keycloak-js": "26.2.4",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular-devkit/core": "22.0.1",
    "@angular-devkit/schematics": "22.0.1",
    "@angular/build": "22.0.1",
    "@angular/cli": "22.0.1",
    "@angular/compiler-cli": "22.0.1",
    "@angular/language-service": "22.0.1",
    "@eslint/js": "10.0.1",
    "@nx/angular": "22.7.5",
    "@nx/devkit": "22.7.5",
    "@nx/eslint": "22.7.5",
    "@nx/eslint-plugin": "22.7.5",
    "@nx/js": "22.7.5",
    "@nx/playwright": "22.7.5",
    "@nx/vitest": "22.7.5",
    "@nx/web": "22.7.5",
    "@nx/workspace": "22.7.5",
    "@playwright/test": "1.60.0",
    "@schematics/angular": "22.0.1",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "@types/node": "25.9.3",
    "@typescript-eslint/utils": "8.61.0",
    "@vitest/coverage-v8": "4.1.8",
    "@vitest/eslint-plugin": "^1.6.20",
    "angular-eslint": "22.0.0",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-jsdoc": "63.0.2",
    "eslint-plugin-n": "^18.1.0",
    "eslint-plugin-no-barrel-files": "^1.3.1",
    "eslint-plugin-playwright": "2.10.4",
    "eslint-plugin-rxjs-angular-x": "^1.0.1",
    "eslint-plugin-rxjs-x": "^1.0.2",
    "eslint-plugin-sonarjs": "4.0.3",
    "eslint-plugin-unicorn": "65.0.1",
    "globals": "17.6.0",
    "husky": "^9.1.7",
    "jiti": "2.7.0",
    "jsdom": "29.1.1",
    "npm-check-updates": "^22.2.3",
    "nx": "22.7.5",
    "prettier": "3.8.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  }
}
